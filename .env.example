# ============================================================
# MeetingIntel Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Required -----

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET_KEY="change-me-generate-with-openssl-rand-base64-32"

# PostgreSQL connection URL (use asyncpg for async)
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/meeting_intel_db"

# OpenAI API key
OPENAI_API_KEY="sk-proj-..."

# ----- Optional but recommended -----

# Runtime environment: development | staging | production
ENVIRONMENT="production"

# PII hash pepper — generate with: openssl rand -base64 32
PII_HASH_PEPPER="change-me-generate-with-openssl-rand-base64-32"

# Redis (required for caching, rate-limiting, and background jobs)
REDIS_URL="redis://localhost:6379/0"
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS="https://your-frontend-domain.com"

# ----- AI model overrides (optional) -----
OPENAI_MODEL="gpt-4o-mini"
OPENAI_FALLBACK_MODEL="gpt-3.5-turbo"
OPENAI_TEMPERATURE=0.3
OPENAI_REQUEST_TIMEOUT=30
OPENAI_MAX_TOKENS_PER_REQUEST=2000
MAX_TRANSCRIPT_TOKENS=12000
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_BASE_WAIT=2

# Google Gemini (optional)
# GOOGLE_API_KEY="your-google-api-key"
# GOOGLE_MODEL="gemini-2.5-pro"
# GOOGLE_FALLBACK_MODEL="gemini-2.5-flash"

# ----- Daily caps (optional, remove to disable) -----
DAILY_TOKEN_CAP=30000
DAILY_COST_CAP_USD=3.00

# ----- Stripe billing (optional — billing endpoints return 503 without these) -----
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRO_PRICE_ID="price_..."
# STRIPE_ENTERPRISE_PRICE_ID="price_..."
# BILLING_ALLOWED_REDIRECT_HOSTS="localhost,127.0.0.1"

# ----- Sentry (optional — only active when SENTRY_DSN is set) -----
# SENTRY_DSN="https://xxx@o0.ingest.sentry.io/0"

# ----- Audio storage (optional — defaults to local /tmp) -----
# STORAGE_BACKEND=local          # or: s3
# STORAGE_LOCAL_DIR=/var/meetingintel/audio
# MAX_AUDIO_BYTES=209715200      # 200 MB
# S3_BUCKET=my-audio-bucket      # required when STORAGE_BACKEND=s3

